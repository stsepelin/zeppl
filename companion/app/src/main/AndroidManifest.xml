<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!-- BLE: scan (with neverForLocation so we don't need location perms)
         + connect. The cluster is the GATT server (peripheral); this app
         is the central, so we don't need BLUETOOTH_ADVERTISE. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
                     android:usesPermissionFlags="neverForLocation"
                     tools:targetApi="31" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"
                     tools:targetApi="31" />

    <!-- Foreground service keeps the BLE link alive while the screen is off.
         CONNECTED_DEVICE is the right subtype for a phone-to-companion link. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- The BLE service upgrades to the LOCATION foreground-service type while a
         speed calibration is running, so GPS keeps flowing with the screen off
         (a plain connectedDevice FGS loses location access when backgrounded on
         Android 14+). Granted only for the duration of a calibration run. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- POST_NOTIFICATIONS is needed to show the foreground-service banner
         on A13+; BIND_NOTIFICATION_LISTENER_SERVICE is signature-level and
         is granted by the user via Settings → Notification access. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Call state is read via TelephonyManager; on A13+ this requires
         READ_PHONE_STATE at runtime. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- ANSWER_PHONE_CALLS gates TelecomManager.acceptRingingCall() and
         endCall() — the actions the cluster's REJECT / ACCEPT / END CALL
         buttons drive over the TX command channel. Runtime grant on A8+. -->
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />

    <!-- Fine location is the GPS speed source for the developer speed-calibration
         wizard (Brick 2): we correlate Location.getSpeed() against the cluster's
         raw ECM count to solve the speed divisor. Coarse location can't deliver
         a usable speed. Not required to run the app - the wizard is the only
         consumer and requests it at runtime. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Filter out devices without BLE. -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <!-- Need to see every installed package, not just launcher-visible
         ones, because system apps that post important notifications
         (Phone, Messages, default Dialer) often don't expose a MAIN /
         LAUNCHER activity. On Play Store this would need a privacy
         disclosure; for a sideloaded companion it's fine. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
                     tools:ignore="QueryAllPackagesPermission" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Zeppl"
        tools:targetApi="36">

        <!-- Portrait-locked: the companion UI is designed for portrait only,
             so we ignore the rotation sensor. resizeableActivity stays true /
             no configChanges: the OS still resizes us on fold/unfold and
             split-screen, and Compose recomposes (currentWindowAdaptiveInfo
             reacts to the new size). Handling the config change ourselves
             would strand stale layouts. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:resizeableActivity="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Zeppl">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- NotificationListener. BIND_NOTIFICATION_LISTENER_SERVICE is
             signature-level — only the system can bind, which it does
             after the user toggles access in Settings. -->
        <service
            android:name=".notif.ZepplNotifListener"
            android:exported="false"
            android:label="@string/notif_listener_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Foreground service hosting the BLE link. The 'connectedDevice'
             type is the right subtype on A14+ for a phone↔companion
             radio link; matches the FOREGROUND_SERVICE_CONNECTED_DEVICE
             permission declared above. -->
        <service
            android:name=".ble.BleService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice|location" />

    </application>
</manifest>
